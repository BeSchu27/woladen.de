SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
CRON_TZ=Europe/Berlin

17 0 * * * __APP_USER__ /usr/bin/flock -n __STATE_DIR__/live-log-archive.lock /bin/bash -lc 'cd __APP_DIR__ && __VENV_DIR__/bin/python -u scripts/live_archive_logs.py --env-file __ENV_FILE__' >> __STATE_DIR__/live-log-archive.log 2>&1
